{
  "name": "file-tree-size-workspace",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "compile": "npm --prefix packages/json-tree-size run compile && npm --prefix packages/xml-tree-size run compile",
    "watch": "npm --prefix packages/json-tree-size run watch",
    "test": "npm --prefix packages/json-tree-size run test",
    "test:all": "npm --prefix packages/json-tree-size run test && npm --prefix packages/xml-tree-size run test",
    "test:stress:json": "npm --prefix packages/json-tree-size run test:stress",
    "test:stress:xml": "npm --prefix packages/xml-tree-size run test:stress",
    "release:json:patch": "npm --prefix packages/json-tree-size run release:patch",
    "release:json:minor": "npm --prefix packages/json-tree-size run release:minor",
    "release:json:major": "npm --prefix packages/json-tree-size run release:major",
    "release:xml:patch": "npm --prefix packages/xml-tree-size run release:patch",
    "release:xml:minor": "npm --prefix packages/xml-tree-size run release:minor",
    "release:xml:major": "npm --prefix packages/xml-tree-size run release:major"
  }
}
