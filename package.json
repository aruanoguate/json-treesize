{
  "name": "json-treesize",
  "displayName": "JSON TreeSize",
  "description": "Visualize JSON file size by path — tree explorer with size bars",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "jsonTreeSize.analyze",
        "title": "JSON TreeSize: Analyze"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "jsonTreeSize.analyze",
          "when": "resourceExtname == .json"
        }
      ],
      "commandPalette": [
        {
          "command": "jsonTreeSize.analyze",
          "when": "resourceExtname == .json"
        }
      ]
    },
    "configuration": {
      "title": "JSON TreeSize",
      "properties": {
        "jsonTreeSize.baseColor": {
          "type": "string",
          "default": "",
          "format": "color-hex",
          "pattern": "^(#[0-9a-fA-F]{6})?$",
          "description": "Base color for the size heat map (hex, e.g. #e06c8a). Leave empty to use the default blue (#4a9eda)."
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "test": "jest"
  },
  "dependencies": {
    "json-source-map": "^0.6.1"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    }
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.4",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.2"
  }
}
