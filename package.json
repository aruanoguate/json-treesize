{
  "name": "json-treesize",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.1.0",
  "publisher": "AlvaroEnriqueRuano",
  "author": {
    "name": "Alvaro Enrique Ruano"
  },
  "license": "MIT",
  "icon": "docs/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aruanoguate/json-treesize"
  },
  "bugs": {
    "url": "https://github.com/aruanoguate/json-treesize/issues"
  },
  "homepage": "https://github.com/aruanoguate/json-treesize#readme",
  "keywords": [
    "json",
    "size",
    "treesize",
    "tree",
    "explorer",
    "analyzer",
    "visualizer",
    "disk usage",
    "file size",
    "json viewer",
    "optimization"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "commands": [
      {
        "command": "jsonTreeSize.analyze",
        "title": "%command.analyze.title%"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "jsonTreeSize.analyze",
          "when": "resourceExtname == .json"
        }
      ],
      "commandPalette": [
        {
          "command": "jsonTreeSize.analyze",
          "when": "resourceExtname == .json"
        }
      ]
    },
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "jsonTreeSize.baseColor": {
          "type": "string",
          "default": "",
          "format": "color-hex",
          "pattern": "^(#[0-9a-fA-F]{6})?$",
          "description": "%config.baseColor.description%"
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "test": "jest",
    "package": "npx @vscode/vsce package --no-yarn",
    "vsce:publish": "npx @vscode/vsce publish --no-yarn",
    "release": "npm test && npm run compile && git push && git push --tags"
  },
  "dependencies": {
    "@vscode/l10n": "^0.0.18",
    "json-source-map": "^0.6.1"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "lcov",
      "text"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    }
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.4",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.2"
  }
}
