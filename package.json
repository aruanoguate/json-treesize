{
  "name": "json-treesize",
  "displayName": "JSON TreeSize",
  "description": "Visualize JSON file size by path — tree explorer with size bars",
  "version": "0.1.0",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "jsonTreeSize.analyze",
        "title": "Analyze with JSON TreeSize"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "jsonTreeSize.analyze",
          "when": "resourceExtname == .json"
        }
      ],
      "commandPalette": [
        {
          "command": "jsonTreeSize.analyze",
          "when": "resourceExtname == .json"
        }
      ]
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "test": "jest"
  },
  "dependencies": {
    "json-source-map": "^0.6.1"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.ts"],
    "globals": {
      "ts-jest": { "tsconfig": "tsconfig.json" }
    }
  }
}
