{
  "name": "xml-tree-size",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "1.0.0",
  "publisher": "AlvaroEnriqueRuano",
  "author": {
    "name": "Alvaro Enrique Ruano"
  },
  "license": "MIT",
  "icon": "docs/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aruanoguate/file-tree-size",
    "directory": "packages/xml-tree-size"
  },
  "bugs": {
    "url": "https://github.com/aruanoguate/file-tree-size/issues"
  },
  "homepage": "https://github.com/aruanoguate/file-tree-size/tree/main/packages/xml-tree-size#readme",
  "keywords": [
    "xml",
    "soap",
    "size",
    "tree-size",
    "analyzer",
    "visualizer",
    "payload"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "commands": [
      {
        "command": "xmlTreeSize.analyze",
        "title": "%command.analyze.title%"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "xmlTreeSize.analyze",
          "when": "resourceExtname == .xml"
        }
      ],
      "commandPalette": [
        {
          "command": "xmlTreeSize.analyze",
          "when": "resourceExtname == .xml"
        }
      ]
    },
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "xmlTreeSize.baseColor": {
          "type": "string",
          "default": "#4a9eda",
          "format": "color-hex",
          "pattern": "^(#[0-9a-fA-F]{6})?$",
          "description": "%config.baseColor.description%"
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "test": "jest",
    "test:stress": "TREE_SIZE_STRESS=1 jest --runInBand tests/parser-xml.stress.test.ts",
    "package": "npx @vscode/vsce package --no-yarn --no-dependencies",
    "vsce:publish": "npx @vscode/vsce publish --no-yarn --no-dependencies",
    "preversion": "npm test && npm run compile",
    "postversion": "git push && git push --tags",
    "release:major": "npm version major --tag-version-prefix xml-v -m 'Release xml %s'",
    "release:minor": "npm version minor --tag-version-prefix xml-v -m 'Release xml %s'",
    "release:patch": "npm version patch --tag-version-prefix xml-v -m 'Release xml %s'",
    "demo": "npx tsx scripts/record-demos.ts",
    "demo:no-gif": "npx tsx scripts/record-demos.ts --no-gif"
  },
  "dependencies": {
    "@vscode/l10n": "^0.0.18",
    "sax": "^1.4.1"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "lcov",
      "text"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/webview/**/*.ts",
      "!src/types.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 100,
        "functions": 100,
        "lines": 100,
        "statements": 100
      }
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/sax": "^1.2.7",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.4",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
